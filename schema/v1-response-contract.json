{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://api.sportsync.io/schemas/match-context/v1",
  "title": "SportsSync Match Context API — v1 Response",
  "description": "Canonical v1 contract for the live match-context endpoint.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "match",
    "teams",
    "market",
    "opening_lines",
    "injuries",
    "intel",
    "metadata"
  ],
  "properties": {
    "match": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "source_id", "sport", "league", "status", "start_time"],
      "properties": {
        "id": { "type": "string", "format": "uuid" },
        "source_id": { "type": "string", "format": "uuid" },
        "external_ids": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "espn": { "type": ["string", "null"] },
            "odds_api": { "type": ["string", "null"] }
          }
        },
        "sport": { "type": "string" },
        "league": { "type": "string" },
        "season": { "type": ["string", "null"] },
        "status": { "type": "string" },
        "start_time": { "type": "string", "format": "date-time" }
      }
    },
    "teams": {
      "type": "object",
      "additionalProperties": false,
      "required": ["home", "away"],
      "properties": {
        "home": { "$ref": "#/definitions/TeamSummary" },
        "away": { "$ref": "#/definitions/TeamSummary" }
      }
    },
    "market": {
      "type": "object",
      "additionalProperties": false,
      "required": ["available"],
      "properties": {
        "available": { "type": "boolean" },
        "consensus": { "$ref": "#/definitions/MarketLine" },
        "books": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["source"],
            "properties": {
              "source": { "type": "string" },
              "spread": { "type": ["number", "null"] },
              "total": { "type": ["number", "null"] },
              "home_ml": { "type": ["integer", "null"] },
              "away_ml": { "type": ["integer", "null"] },
              "draw_ml": { "type": ["integer", "null"] }
            }
          }
        },
        "source": { "type": ["string", "null"] },
        "fetched_at": { "type": ["string", "null"], "format": "date-time" }
      }
    },
    "opening_lines": {
      "type": "object",
      "additionalProperties": false,
      "required": ["available", "lines"],
      "properties": {
        "available": { "type": "boolean" },
        "lines": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["source"],
            "properties": {
              "source": { "type": "string" },
              "spread": { "type": ["number", "null"] },
              "total": { "type": ["number", "null"] },
              "home_ml": { "type": ["integer", "null"] },
              "away_ml": { "type": ["integer", "null"] },
              "draw_ml": { "type": ["integer", "null"] },
              "captured_at": { "type": ["string", "null"], "format": "date-time" }
            }
          }
        }
      }
    },
    "injuries": {
      "type": "object",
      "additionalProperties": false,
      "required": ["available", "home", "away"],
      "properties": {
        "available": { "type": "boolean" },
        "home": { "type": "array", "items": { "$ref": "#/definitions/InjuryItem" } },
        "away": { "type": "array", "items": { "$ref": "#/definitions/InjuryItem" } }
      }
    },
    "intel": {
      "type": "object",
      "additionalProperties": false,
      "required": ["available"],
      "properties": {
        "available": { "type": "boolean" },
        "headline": { "type": ["string", "null"] },
        "recommended_pick": { "type": ["string", "null"] },
        "confidence_tier": { "type": ["string", "null"] },
        "logic_group": { "type": ["string", "null"] },
        "briefing": { "type": ["string", "null"] },
        "pick_summary": { "type": ["string", "null"] },
        "cards": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true,
            "properties": {
              "title": { "type": ["string", "null"] },
              "detail": { "type": ["string", "null"] }
            }
          }
        },
        "grading_metadata": { "type": ["object", "null"], "additionalProperties": true },
        "generated_at": { "type": ["string", "null"], "format": "date-time" }
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "api_version",
        "generated_at",
        "response_time_ms",
        "data_freshness",
        "sections_available",
        "warnings"
      ],
      "properties": {
        "api_version": { "type": "string", "const": "v1" },
        "generated_at": { "type": "string", "format": "date-time" },
        "response_time_ms": { "type": "integer" },
        "data_freshness": {
          "type": "object",
          "additionalProperties": { "$ref": "#/definitions/FreshnessIndicator" }
        },
        "sections_available": {
          "type": "object",
          "additionalProperties": { "type": "boolean" }
        },
        "warnings": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true,
            "properties": {
              "code": { "type": ["string", "null"] },
              "section": { "type": ["string", "null"] },
              "message": { "type": ["string", "null"] }
            }
          }
        }
      }
    }
  },
  "definitions": {
    "TeamSummary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "score"],
      "properties": {
        "name": { "type": "string" },
        "score": { "type": ["integer", "null"] }
      }
    },
    "MarketLine": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "properties": {
        "spread": { "type": ["number", "null"] },
        "total": { "type": ["number", "null"] },
        "home_ml": { "type": ["integer", "null"] },
        "away_ml": { "type": ["integer", "null"] },
        "draw_ml": { "type": ["integer", "null"] }
      }
    },
    "InjuryItem": {
      "type": "object",
      "additionalProperties": false,
      "required": ["player_name", "status", "report", "report_date"],
      "properties": {
        "player_name": { "type": "string" },
        "status": { "type": "string" },
        "report": { "type": ["string", "null"] },
        "report_date": { "type": ["string", "null"], "format": "date" }
      }
    },
    "FreshnessIndicator": {
      "type": "object",
      "additionalProperties": false,
      "required": ["last_updated", "status", "source"],
      "properties": {
        "last_updated": { "type": ["string", "null"], "format": "date-time" },
        "status": { "type": "string", "enum": ["fresh", "stale", "unavailable"] },
        "source": { "type": ["string", "null"] }
      }
    }
  }
}
