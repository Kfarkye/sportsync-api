{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://api.sportsync.io/schemas/match-context/v1-live",
  "title": "SportsSync Match Context API — v1 Live Contract",
  "description": "Canonical public contract aligned to the live match-context runtime.",
  "type": "object",
  "required": [
    "match",
    "teams",
    "intel",
    "injuries",
    "opening_lines",
    "market",
    "metadata"
  ],
  "additionalProperties": false,
  "properties": {
    "match": {
      "type": "object",
      "required": ["id", "source_id", "external_ids", "sport", "league", "season", "status", "start_time"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string" },
        "source_id": { "type": "string" },
        "external_ids": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "espn": { "type": ["string", "null"] },
            "odds_api": { "type": ["string", "null"] },
            "sofascore": { "type": ["string", "null"] }
          }
        },
        "sport": { "type": "string" },
        "league": { "type": "string" },
        "season": { "type": "string" },
        "status": { "type": "string" },
        "start_time": { "type": "string", "format": "date-time" }
      }
    },
    "teams": {
      "type": "object",
      "required": ["home", "away"],
      "additionalProperties": false,
      "properties": {
        "home": { "$ref": "#/definitions/TeamSide" },
        "away": { "$ref": "#/definitions/TeamSide" }
      }
    },
    "intel": {
      "type": "object",
      "required": ["available"],
      "additionalProperties": false,
      "properties": {
        "available": { "type": "boolean" },
        "headline": { "type": ["string", "null"] },
        "recommended_pick": { "type": ["string", "null"] },
        "confidence_tier": { "type": ["string", "null"] },
        "logic_group": { "type": ["string", "null"] },
        "briefing": { "type": ["string", "null"] },
        "pick_summary": { "type": ["string", "null"] },
        "cards": {
          "type": "array",
          "items": { "$ref": "#/definitions/IntelCard" }
        },
        "grading_metadata": {
          "type": "object",
          "additionalProperties": true
        },
        "generated_at": { "type": ["string", "null"], "format": "date-time" }
      }
    },
    "injuries": {
      "type": "object",
      "required": ["available", "home", "away"],
      "additionalProperties": false,
      "properties": {
        "available": { "type": "boolean" },
        "home": {
          "type": "array",
          "items": { "$ref": "#/definitions/InjuryItem" }
        },
        "away": {
          "type": "array",
          "items": { "$ref": "#/definitions/InjuryItem" }
        }
      }
    },
    "opening_lines": {
      "type": "object",
      "required": ["available", "lines"],
      "additionalProperties": false,
      "properties": {
        "available": { "type": "boolean" },
        "lines": {
          "type": "array",
          "items": { "$ref": "#/definitions/OpeningLine" }
        }
      }
    },
    "market": {
      "type": "object",
      "required": ["available", "consensus", "books", "source", "fetched_at"],
      "additionalProperties": false,
      "properties": {
        "available": { "type": "boolean" },
        "consensus": {
          "type": ["object", "null"],
          "additionalProperties": false,
          "properties": {
            "spread": { "type": ["number", "null"] },
            "total": { "type": ["number", "null"] },
            "home_ml": { "type": ["integer", "null"] },
            "away_ml": { "type": ["integer", "null"] },
            "draw_ml": { "type": ["integer", "null"] }
          }
        },
        "books": {
          "type": "array",
          "items": { "type": "object", "additionalProperties": true }
        },
        "source": { "type": ["string", "null"] },
        "fetched_at": { "type": ["string", "null"], "format": "date-time" }
      }
    },
    "metadata": {
      "type": "object",
      "required": ["api_version", "generated_at", "response_time_ms", "data_freshness", "sections_available", "warnings"],
      "additionalProperties": false,
      "properties": {
        "api_version": { "type": "string", "const": "v1" },
        "generated_at": { "type": "string", "format": "date-time" },
        "response_time_ms": { "type": "integer" },
        "data_freshness": {
          "type": "object",
          "additionalProperties": { "$ref": "#/definitions/FreshnessIndicator" }
        },
        "sections_available": {
          "type": "object",
          "additionalProperties": { "type": "boolean" }
        },
        "warnings": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true
          }
        }
      }
    }
  },
  "definitions": {
    "TeamSide": {
      "type": "object",
      "required": ["name", "score"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "score": { "type": ["integer", "null"] }
      }
    },
    "IntelCard": {
      "type": "object",
      "required": ["title", "detail"],
      "additionalProperties": false,
      "properties": {
        "title": { "type": "string" },
        "detail": { "type": "string" }
      }
    },
    "InjuryItem": {
      "type": "object",
      "required": ["player_name", "status", "report", "report_date"],
      "additionalProperties": false,
      "properties": {
        "player_name": { "type": "string" },
        "status": { "type": "string" },
        "report": { "type": ["string", "null"] },
        "report_date": { "type": ["string", "null"] }
      }
    },
    "OpeningLine": {
      "type": "object",
      "required": ["source", "spread", "total", "home_ml", "away_ml", "draw_ml", "captured_at"],
      "additionalProperties": false,
      "properties": {
        "source": { "type": ["string", "null"] },
        "spread": { "type": ["number", "null"] },
        "total": { "type": ["number", "null"] },
        "home_ml": { "type": ["integer", "null"] },
        "away_ml": { "type": ["integer", "null"] },
        "draw_ml": { "type": ["integer", "null"] },
        "captured_at": { "type": ["string", "null"], "format": "date-time" }
      }
    },
    "FreshnessIndicator": {
      "type": "object",
      "required": ["last_updated", "status", "source"],
      "additionalProperties": false,
      "properties": {
        "last_updated": { "type": ["string", "null"], "format": "date-time" },
        "status": { "type": "string" },
        "source": { "type": ["string", "null"] }
      }
    }
  }
}
